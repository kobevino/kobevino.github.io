{
  "include": ["./src/**/*"],
  "compilerOptions": {
    "baseUrl": "src",
    "target": "esnext",
    "module": "CommonJS",
    "lib": ["dom", "es2017"],
    // "allowJs": true,
    // "checkJs": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "Node",
    "jsxImportSource": "@emotion/react",
    "types": ["@emotion/react"]
  }
}